# Required Wi-Fi settings.
CIRCUITPY_WIFI_SSID="your-ssid"
CIRCUITPY_WIFI_PASSWORD="your-password"

# Optional HTTP settings.
HTTP_PORT="80"
HTTP_DEBUG="false"

# MQTT broker settings. These are required if you want Home Assistant discovery.
MQTT_BROKER="192.168.1.10"
MQTT_PORT="1883"
MQTT_USERNAME="mqtt-user"
MQTT_PASSWORD="mqtt-password"
MQTT_USE_SSL="false"
MQTT_CLIENT_ID="usb-host-waker"
MQTT_TOPIC_PREFIX="usb_host_waker"
MQTT_WAKE_PAYLOAD="WAKE"

# Home Assistant MQTT discovery settings.
HA_DISCOVERY_PREFIX="homeassistant"
HA_STATUS_TOPIC="homeassistant/status"
HA_STATUS_ONLINE_PAYLOAD="online"
HA_DEVICE_ID="usb_host_waker_01"
HA_DEVICE_NAME="USB Host Waker"
HA_DEVICE_MANUFACTURER="CircuitPython"
HA_DEVICE_MODEL="ESP32-S2"
HA_DEVICE_HW_VERSION="rev-a"
HA_DEVICE_SW_VERSION="2.0.0"
HA_SUGGESTED_AREA="Desk"

# Runtime tuning.
WIFI_MAX_RETRIES="10"
WIFI_RETRY_DELAY_S="2"
WIFI_CHECK_INTERVAL_S="5"
MAIN_LOOP_DELAY_S="0.05"
SERVICE_RESTART_DELAY_S="1"
HTTP_RESTART_INTERVAL_S="3600"
HTTP_ERROR_RETRY_DELAY_S="1"
MQTT_KEEP_ALIVE="60"
MQTT_RETRY_DELAY_S="10"
MQTT_STATUS_PUBLISH_INTERVAL_S="30"

# Required CircuitPython libraries in /lib:
# - adafruit_hid
# - adafruit_httpserver
# - adafruit_minimqtt
